{
  "name": "cuedesk-site",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.30.3",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.5"
  },
  "scripts": {
    "tailwind": "tailwindcss -i ./src/tailwind.input.css -o ./src/tailwind.output.css",
    "prestart": "npm run tailwind",
    "start": "concurrently \"tailwindcss -i ./src/tailwind.input.css -o ./src/tailwind.output.css --watch\" \"react-scripts start\"",
    "prebuild": "npm run tailwind -- --minify",
    "build": "react-scripts build",
    "postbuild": "react-snap",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "reactSnap": {
    "include": ["/", "/sales", "/teams", "/never-blank"],
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"]
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.9",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.19"
  }
}
